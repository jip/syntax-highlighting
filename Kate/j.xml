<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE language SYSTEM "language.dtd">
<!--
  j.xml syntax highlighting for J programming languase under Kate

  J is a modern, high-level, general-purpose, high-performance, portable programming language.
  http://www.jsoftware.com
  
  Kate is a KDE Advanced Text Editor
  http://kate.kde.org/
  -->
<language name="J" version="1.0" kateversion="2.3" section="Sources" extensions="*.ijs;*IJS;*.ijx;*.IJX;*.ijt;*.IJT;*.ijl;*.IJL" author="Igor Zhuravlov (|.'ur.ugvd.ciu@rogi')" license="GPL">
	<highlighting>
	<list name="keywords">
		<item> assert. </item>
		<item> break. </item>
		<item> case. </item>
		<item> catch. </item>
		<item> catchd. </item>
		<item> catcht. </item>
		<item> continue. </item>
		<item> do. </item>
		<item> else. </item>
		<item> elseif. </item>
		<item> end. </item>
		<item> fcase. </item>
		<item> for. </item>
		<item> for_</item>
		<item> goto_</item>
		<item> if. </item>
		<item> label_</item>
		<item> return. </item>
		<item> select. </item>
		<item> throw. </item>
		<item> trap. </item>
		<item> try. </item>
		<item> while. </item>
		<item> whilst. </item>
		<item> NB. </item>
	</list>
	<list name="function definitions">
		<item>=:</item>
		<item>=.</item>
	</list>
	<contexts>
		<context attribute="Normal Text" lineEndContext="#stay" name="normal">
			<StringDetect attribute="Comment" context="comment_single_line" String="NB." />
			<keyword attribute="Keyword" context="#stay" String="keywords" />
			<DetectChar attribute="String" context="string" char="'" />
			<RegExpr attribute="Normal Text" context="#stay" String="\w[']+" />
			<RegExpr attribute="Function Definition" context="#stay" String="[a-z_]+\w*'*\s*::" />
			<Float attribute="Float" context="#stay" />
			<Int attribute="Decimal" context="#stay" />
		</context>
		<context attribute="Comment" lineEndContext="#pop" name="comment_single_line" />
		<context attribute="String" lineEndContext="#stay" name="string">
			<RegExpr attribute="String" context="#stay" String="\\." />
			<DetectChar attribute="String" context="#pop" char="'" />
		</context>
	</contexts>
	<itemDatas>
		<itemData name="Normal Text"		defStyleNum="dsNormal"   color="1818b2"/>
		<itemData name="Keyword" 		defStyleNum="dsKeyword"  color="ff5454" bold="1"/>
		<itemData name="Function"		defStyleNum="dsFunction"/>
		<itemData name="Function Definition"	defStyleNum="dsFunction"/>
		<itemData name="Decimal"		defStyleNum="dsDecVal"/>
		<itemData name="Float"			defStyleNum="dsFloat"/>
		<itemData name="Char"			defStyleNum="dsChar"/>
		<itemData name="String"			defStyleNum="dsString"   color="54ffff"/> <!-- 54ff54 -->
		<itemData name="Comment"		defStyleNum="dsComment"  color="18b218"/>
	</itemDatas>
	</highlighting>
	<general>
		<comments>
			<comment name="singleLine" start="NB." />
		</comments>
		<keywords casesensitive="1" />
	</general>
</language>
